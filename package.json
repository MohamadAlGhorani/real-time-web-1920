{
  "name": "party-2020",
  "version": "1.0.0",
  "description": "A real-time collaborative Spotify listening party app. Users authenticate with Spotify, create or join party rooms, and listen to music together in sync.",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "directories": {
    "doc": "docs",
    "example": "examples"
  },
  "scripts": {
    "prestart": "npm run build",
    "predev": "npm run build",
    "dev": "nodemon server.js",
    "start": "node server.js",
    "prebuild": "rimraf ./static",
    "build": "npm-run-all build:*",
    "build:css": "node scripts/build-css.js",
    "build:js": "node scripts/build-js.js",
    "build:assets": "node scripts/build-assets.js",
    "watch": "npm-run-all watch:*",
    "watch:js": "chokidar 'src/js/*.js' --command 'npm run build:js'",
    "watch:css": "chokidar 'src/css/style.css' --command 'npm run build:css'",
    "watch:assets": "chokidar 'src/**/*.*' --command 'npm run build:assets'",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MohamadAlGhorani/party-2020.git"
  },
  "author": "Mohamad Al Ghorani",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/MohamadAlGhorani/party-2020/issues"
  },
  "homepage": "https://github.com/MohamadAlGhorani/party-2020#readme",
  "dependencies": {
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "mongoose": "^8.12.1",
    "node-fetch": "^2.7.0",
    "query-string": "^6.14.1",
    "socket.io": "^4.8.3",
    "spotify-web-api-node": "^5.0.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "chokidar-cli": "^3.0.0",
    "clean-css": "^5.3.3",
    "ncp": "^2.0.0",
    "nodemon": "^3.1.9",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "rimraf": "^5.0.10"
  }
}
