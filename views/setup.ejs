<%- include('./partials/head.ejs') %>

<main id="main" class="auth-page setup-page" role="main" aria-label="Party setup">
	<div class="auth-card" role="region" aria-labelledby="setup-heading">
		<div class="logo" id="setup-heading" role="heading" aria-level="1"><img src="/favicon.svg" alt="" class="logo-icon" aria-hidden="true">Party 2020</div>
		<p class="subtitle">Choose a playlist for your party</p>
		<div class="divider" role="separator"></div>

		<nav class="playlist-grid" aria-label="Your playlists">
			<% playlistsData.items.forEach(function(playlist) { %>
				<a href="/party-<%= playlist.id %>" class="playlist-item" aria-label="Start party with <%= playlist.name %>">
					<span class="material-symbols-outlined" aria-hidden="true">queue_music</span>
					<span><%= playlist.name %></span>
					<span class="material-symbols-outlined" style="color: var(--text-muted); font-size: 18px;" aria-hidden="true">arrow_forward_ios</span>
				</a>
			<% }) %>
		</nav>
	</div>
</main>

<%- include('./partials/footer.ejs') %>
